= {item[\"value\"]: item for item in color_mapping_data[\"land_cover\"]}\n\n# Create cmap and norm for plotting\ncolors = [info[\"color\"] for info in color_mapping.values()]\ncategories = [info[\"value\"] for info in color_mapping.values()]\ncmap = ListedColormap(colors)\nnorm = BoundaryNorm(categories + [max(categories) + 1], len(categories))","key":"JlKUuCqkn7"},{"type":"outputs","id":"D5HAZZ865jatgVnHFkYUW","children":[],"key":"dv9vhdxvWN"}],"key":"KkrpJSxf9I"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Now we can plot the CORINE Land Cover dataset.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"ePaWe29Ykd"}],"key":"cap1ItnrMb"}],"key":"tCjPCdSKS9"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Get landcover codes present in the image\npresent_landcover_codes = np.unique(cor_da.values[~np.isnan(cor_da.values)].astype(int))\n\n# Get colors + text for legend\nhandles = [\n    mpatches.Patch(color=info[\"color\"], label=(f\"{info['value']} - \" + (info[\"label\"])))\n    for info in color_mapping.values()\n    if info[\"value\"] in present_landcover_codes\n]\n\n# Create the plot\ncor_da.plot(figsize=(10, 10), cmap=cmap, norm=norm, add_colorbar=False).axes.set_aspect(\n    \"equal\"\n)\n\nplt.legend(\n    handles=handles,\n    bbox_to_anchor=(1.01, 1),\n    loc=\"upper left\",\n    borderaxespad=0,\n    fontsize=7,\n)\nplt.title(\"CORINE Land Cover (EPSG:27704)\")","key":"UrQmenDEWy"},{"type":"outputs","id":"ERPqZHO_CFG1ZlzlOx0q1","children":[],"key":"orC7GO6KrY"}],"key":"CsTqico4y7"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Now we are ready to merge the backscatter data (","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Tvx3WIsA9S"},{"type":"inlineCode","value":"sig0_da","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"eBnQd4RvNN"},{"type":"text","value":") with the land cover dataset (","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"CobocrLv5h"},{"type":"inlineCode","value":"cor_da","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"wzXLJlOpqO"},{"type":"text","value":") to have one dataset combining all data.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"irgAio7Mde"}],"key":"rIMx9BDig2"}],"key":"WUWtlHlVHi"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"var_ds = xr.merge([sig0_da, cor_da]).drop_vars(\"band\")\nvar_ds","key":"ko78txlYnh"},{"type":"outputs","id":"zr8RyTJ-_0EfIBCmv9K29","children":[],"key":"DH7fjiZ70l"}],"key":"LMcNgJC8kN"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Backscatter Variability","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"zaZeQYCoca"}],"identifier":"backscatter-variability","label":"Backscatter Variability","html_id":"backscatter-variability","implicit":true,"key":"lLFc58FIDr"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"With this combined dataset we can study backscatter variability in relation to natural media. For example we can look at the backscatter variability for water by clipping the dataset to only contain the land cover class water, like so:","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"MjCbN8OzBt"}],"key":"hzgA9qFzCB"}],"key":"l67a74UMr7"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# 41 = encoded value for water bodies\nwaterbodies_mask = var_ds.land_cover == 41\nwaterbodies_mask.plot().axes.set_aspect(\"equal\")","key":"E5J1nLddqX"},{"type":"outputs","id":"KW-wDjwp1A5Pz8RaJvZF3","children":[],"key":"FXse6sx2Qz"}],"key":"bsJyn2TDdF"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"This gives use backscatter values over water only.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"HO7BLk6wHR"}],"key":"je2SGpYFw4"}],"key":"PnwTfgDmHk"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"waterbodies_sig0 = var_ds.sig0.isel(time=0).where(waterbodies_mask)\nwaterbodies_sig0.plot(robust=True, cmap=\"Greys_r\").axes.set_aspect(\"equal\")","key":"sGltclsT7H"},{"type":"outputs","id":"mwtF5y2BSDUDFk2I7uctH","children":[],"key":"w4AugFYkBf"}],"key":"hA4n441WxW"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"To get an idea of the variability we can create a histogram. Radar backscatter from water bodies fluctuates with surface roughness, which changes with wind conditions, creating spatial and temporal variations in signal intensity.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"LpRdCG2Nt2"}],"key":"qw6IZbtkNt"}],"key":"mbPUOcIG8s"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"waterbodies_sig0.plot.hist(bins=50, edgecolor=\"black\")","key":"LrUQNrwUUU"},{"type":"outputs","id":"BMRlEKv27ai5Pul2Finji","children":[],"key":"J0awiyCFVU"}],"key":"mlHzzMA5fh"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Variability over Time","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"gpXJDLL5Nd"}],"identifier":"variability-over-time","label":"Variability over Time","html_id":"variability-over-time","implicit":true,"key":"Yf0Cs4Sa6x"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"Next we will look at the changes in variability in backscatter values over time for each of the CORINE Land Cover types. We do this by creating the following interactive plot. We can spot that backscatter in agricultural fields varies due to seasonal cycles like planting, growing, and harvesting, each of which changes vegetation structure. Changes in backscatter are strongly related to soil moisture content from irrigation or rainfall. Ultimately, phenological stages of crops and canopy moisture dynamics can affect the backscatter signal.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"eicsBsSDCc"}],"key":"nnIh8FWhD1"}],"key":"bJTDemES2T"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"robust_min = var_ds.sig0.quantile(0.02).item()\nrobust_max = var_ds.sig0.quantile(0.98).item()\n\nbin_edges = [\n    i + j * 0.5\n    for i in range(int(robust_min) - 2, int(robust_max) + 2)\n    for j in range(2)\n]\n\nland_cover = {\"\\xa0\\xa0\\xa0 Complete Land Cover\": 1}\nland_cover.update(\n    {\n        f\"{int(value): 02} {color_mapping[value]['label']}\": int(value)\n        for value in present_landcover_codes\n    }\n)\ntime = var_ds.sig0[\"time\"].values\n\nrangexy = RangeXY()\n\n\ndef load_image(time, land_cover, x_range, y_range):\n    \"\"\"Callback Function Landcover.\n\n    Parameters\n    ----------\n    time: panda.datatime\n        time slice\n    landcover: int\n        land cover type\n    x_range: array_like\n        longitude range\n    y_range: array_like\n        latitude range\n\n    Returns\n    -------\n    holoviews.Image\n\n    \"\"\"\n    if land_cover == \"\\xa0\\xa0\\xa0 Complete Land Cover\":\n        sig0_selected_ds = var_ds.sig0.sel(time=time)\n\n    else:\n        land_cover_value = int(land_cover.split()[0])\n        mask_ds = var_ds.land_cover == land_cover_value\n        sig0_selected_ds = var_ds.sig0.sel(time=time).where(mask_ds)\n\n    hv_ds = hv.Dataset(sig0_selected_ds)\n    img = hv_ds.to(hv.Image, [\"x\", \"y\"])\n\n    if x_range and y_range:\n        img = img.select(x=x_range, y=y_range)\n\n    return hv.Image(img)\n\n\ndmap = (\n    hv.DynamicMap(load_image, kdims=[\"Time\", \"Landcover\"], streams=[rangexy])\n    .redim.values(Time=time, Landcover=land_cover)\n    .hist(normed=True, bins=bin_edges)\n)\n\nimage_opts = hv.opts.Image(\n    cmap=\"Greys_r\",\n    colorbar=True,\n    tools=[\"hover\"],\n    clim=(robust_min, robust_max),\n    aspect=\"equal\",\n    framewise=False,\n    frame_height=500,\n    frame_width=500,\n)\n\nhist_opts = hv.opts.Histogram(width=350, height=555)\n\ndmap.opts(image_opts, hist_opts)","key":"Dn000OrByK"},{"type":"outputs","id":"Dw91p3McGTg_oEWU_rS62","children":[],"key":"s35CoC7cw9"}],"key":"sBeelkJfv7"}],"key":"mLELHz70BU"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Wavelength and Polarization","url":"/notebooks/courses/microwave-remote-sensing/unit-02/in-class-exercise-1","group":"Courses"},"next":{"title":"Speckle Statistics","url":"/notebooks/courses/microwave-remote-sensing/unit-03/in-class-exercise","group":"Courses"}}},"domain":"http://localhost:3000"}